{
  "version": 2,
  "builds": [
    {
      "src": "naimos-backend/src/server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["naimos-backend/src/**"]
      }
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api-client.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "naimos-backend/src/server.ts" },
    { "src": "/api-client.js", "dest": "/api-client.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}